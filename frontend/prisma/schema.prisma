generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum BookingType {
  flight
  stay
}

enum BookingStatus {
  pending
  confirmed
  failed
  cancelled
}

enum SearchType {
  flight
  stay
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  fullName         String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  travellerProfiles TravellerProfile[]
  searches         SearchRecord[]
  bookings         Booking[]
}

model TravellerProfile {
  id                  String   @id @default(cuid())
  userId              String
  fullName            String
  email               String?
  phoneNumber         String?
  dateOfBirth         DateTime?
  title               String?
  gender              String?
  loyaltyAirlineCode  String?
  loyaltyAccountNumber String?
  passportNumber      String?
  passportCountryCode String?
  passportExpiresOn   DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SearchRecord {
  id                String     @id @default(cuid())
  userId            String?
  type              SearchType
  originCode        String?
  destinationCode   String?
  destinationQuery  String?
  departureDate     DateTime?
  returnDate        DateTime?
  checkInDate       DateTime?
  checkOutDate      DateTime?
  cabinClass        String?
  adults            Int?
  rooms             Int?
  guests            Int?
  offerRequestId    String?
  metadata          Json?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  user              User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  bookings          Booking[]

  @@index([userId, type])
  @@index([offerRequestId])
}

model Booking {
  id                String          @id @default(cuid())
  userId            String?
  searchRecordId    String?
  type              BookingType
  status            BookingStatus   @default(pending)
  duffelOrderId     String?         @unique
  bookingReference  String?
  currency          String?
  totalAmount       Decimal?        @db.Decimal(10, 2)
  offerId           String?
  providerName      String?
  metadata          Json?
  bookedAt          DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  user              User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  searchRecord      SearchRecord?   @relation(fields: [searchRecordId], references: [id], onDelete: SetNull)
  passengers        BookingPassenger[]

  @@index([userId, type, status])
  @@index([searchRecordId])
  @@index([offerId])
}

model Airline {
  id             String   @id @default(cuid())
  iataCode       String?  @unique
  icaoCode       String?  @unique
  name           String
  legalName      String?
  alliance       String?
  countryCode    String?
  countryName    String?
  callsign       String?
  websiteUrl     String?
  supportPhone   String?
  logoUrl        String?
  logoLocalPath  String?
  isActive       Boolean  @default(true)
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([name])
  @@index([countryCode])
}

model BookingPassenger {
  id                     String   @id @default(cuid())
  bookingId              String
  duffelPassengerId      String?
  type                   String?
  title                  String?
  gender                 String?
  givenName              String
  familyName             String
  bornOn                 DateTime?
  email                  String?
  phoneNumber            String?
  loyaltyAirlineCode     String?
  loyaltyAccountNumber   String?
  identityDocumentType   String?
  identityDocumentNumber String?
  issuingCountryCode     String?
  expiresOn              DateTime?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  booking                Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([duffelPassengerId])
}
